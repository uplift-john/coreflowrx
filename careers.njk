 <div class="visually-hidden" aria-hidden="true">
 <label for="ap-website">Leave this field empty</label>
 <input id="ap-website" name="website" type="text" tabindex="-1" autocomplete="off">
 </div>
 <div><button class="btn btn--primary" type="submit">Submit Your Application →</button></div>
